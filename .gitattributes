# Force YAML text for Unity assets to enable proper diff/merge
*.unity merge=unityyamlmerge eol=lf
*.prefab merge=unityyamlmerge eol=lf
*.asset merge=unityyamlmerge eol=lf
*.meta merge=unityyamlmerge eol=lf
*.controller merge=unityyamlmerge eol=lf
*.anim merge=unityyamlmerge eol=lf
*.physicMaterial merge=unityyamlmerge eol=lf
*.physicsMaterial2D merge=unityyamlmerge eol=lf
*.mat merge=unityyamlmerge eol=lf
*.lighting merge=unityyamlmerge eol=lf

# Mark binary assets so git treats them as binary (no text/CRLF conversion, no diff/merge)
*.cubemap binary
*.unity3d binary
*.jpg binary
*.jpeg binary
*.png binary
*.psd binary
*.tga binary
*.tif binary
*.tiff binary
*.exr binary
*.hdr binary
*.mp3 binary
*.wav binary
*.ogg binary
*.aif binary
*.aiff binary
*.mp4 binary
*.mov binary
*.webm binary
*.fbx binary
*.obj binary
*.blend binary
*.ttf binary
*.otf binary
